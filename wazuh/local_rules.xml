<group name="suricata,">
  
  <rule id="100001" level="3">
    <decoded_as>json</decoded_as>
    <field name="alert.signature_id">1000001</field>
    <description>Suricata: Single SSH brute-force attempt detected.</description>
  </rule>
  
  <rule id="100002" level="10" frequency="3" timeframe="60">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>Suricata: Multiple SSH brute-force attempts from same source.</description>
  </rule>
  
</group>
