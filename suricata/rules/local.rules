alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"SOC-LAB Potential SSH brute-force"; flow:to_server,established; classtype:attempted-admin; sid:1000001; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"SOC-LAB Port scan detected"; flags:S; threshold:type both,track by_src,count 20,seconds 5; classtype:attempted-recon; sid:1000002; rev:1;)

alert http $EXTERNAL_NET any -> $HOME_NET 80 (msg:"SOC-LAB Exploit attempt - cmd injection"; flow:to_server,established; content:"|3B|wget|20|http"; nocase; http_uri; metadata:attack-target WebServer, cve CVE-2021-41773; classtype:web-application-attack; sid:1000003; rev:1;)
